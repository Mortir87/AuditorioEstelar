<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginTop="70dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        android:layout_gravity="center_horizontal"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dorado_redondeado"
        android:orientation="vertical"
        android:layout_margin="10dp"
        android:layout_marginTop="15dp"
        android:padding="5dp">
    <TextView
        android:id="@+id/textViewPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Mi cuenta"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        android:layout_marginStart="20dp"
        android:layout_gravity="left"
        android:drawableStart="@drawable/outline_account_circle_24"
        />
    <TextView
        android:id="@+id/textViewVerTodaLaProgramacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Ver toda la programacion"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_gravity="left"
        android:drawableStart="@drawable/outline_bookmark_24"
        android:drawableTint="@color/azul_primario"
        />
    <TextView
        android:id="@+id/textViewVerCalendario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Calendario"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_gravity="left"
        android:drawableStart="@drawable/rounded_calendar_month_24"
        android:drawableTint="@color/azul_primario"
        />
    <TextView
        android:id="@+id/textViewSobreNosotros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="   Sobre nosotros"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_gravity="left"
        android:drawableStart="@drawable/sharp_cards_star_24"
        android:drawableTint="@color/azul_primario"
        />
    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Donde estamos:"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:layout_gravity="left"
        />
    <ImageView
        android:id="@+id/iv_mapa_estatico"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ubicacion"
        android:contentDescription="Ubicación en el mapa"
        android:layout_margin="10dp"
          />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guia de uso"
        android:layout_gravity="left"
        android:layout_marginStart="20dp"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Condiciones de venta"
        android:layout_gravity="left"
        android:layout_marginStart="20dp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Politica de privacidad"
        android:layout_gravity="left"
        android:layout_marginStart="20dp"
        android:textStyle="bold"
        android:textColor="@color/azul_primario"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="Version: Proyecto Final DAM II - V. 1b"
        android:layout_marginStart="20dp"
        android:paddingBottom="5dp"
        android:textColor="@color/dorado_primario"
        android:gravity="bottom"
        />
</LinearLayout>
